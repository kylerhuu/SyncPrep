# OpenAI API key (required for AI prep notes)
OPENAI_API_KEY=sk-...

# Google OAuth (required for Google Calendar import)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:3000/api/auth/google/callback (and your production URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 32+ character secret for encrypting OAuth tokens in cookies
SESSION_SECRET=your-32-char-or-longer-secret-here

# =============================================================================
# SyncPrep Environment Variables
# =============================================================================
# Copy to .env.local (development) or set in Vercel Project Settings (production)
# =============================================================================

# Required for meeting brief generation (AI prep notes)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Google Calendar (optional)
# Required only if you want calendar import. App works without it.
# -----------------------------------------------------------------------------
# Create OAuth credentials: https://console.cloud.google.com/apis/credentials
# Add redirect URIs in Google Console:
#   - Development: http://localhost:3000/api/auth/google/callback
#   - Production:  https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required when using Google Calendar. 32+ char random string for token encryption.
# Generate: openssl rand -base64 32
SESSION_SECRET=your-32-char-or-longer-secret-here
